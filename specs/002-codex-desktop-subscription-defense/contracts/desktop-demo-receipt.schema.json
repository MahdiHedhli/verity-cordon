{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:verity-cordon:schema:desktop-demo-receipt:1.0.0",
  "title": "Verity Cordon Codex Desktop Demo Receipt",
  "description": "Private write-ahead receipt for the reversible synthetic Codex Desktop MCP fixture. The receipt contains no credentials, raw evidence, or arbitrary existing MCP configuration.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_version",
    "installation_id",
    "state",
    "operator_confirmed",
    "confirmation_method",
    "preview_digest",
    "confirmed_at",
    "created_at",
    "updated_at",
    "digest_algorithm",
    "codex_home",
    "config_path",
    "staging_root",
    "config_existed_before",
    "config_before_sha256",
    "config_after_sha256",
    "backup_path",
    "backup_sha256",
    "managed_entry_original",
    "managed_entry",
    "codex_runtime",
    "python_runtime",
    "artifacts",
    "normal_integration",
    "teardown"
  ],
  "properties": {
    "receipt_version": {
      "const": "1.0.0"
    },
    "installation_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "state": {
      "enum": [
        "prepared",
        "installed",
        "removing",
        "removed"
      ]
    },
    "operator_confirmed": {
      "const": true
    },
    "confirmation_method": {
      "enum": [
        "cli_yes",
        "interactive"
      ]
    },
    "preview_digest": {
      "$ref": "#/$defs/sha256Hex"
    },
    "confirmed_at": {
      "$ref": "#/$defs/dateTime"
    },
    "created_at": {
      "$ref": "#/$defs/dateTime"
    },
    "updated_at": {
      "$ref": "#/$defs/dateTime"
    },
    "digest_algorithm": {
      "const": "SHA-256"
    },
    "codex_home": {
      "$ref": "#/$defs/absolutePath"
    },
    "config_path": {
      "$ref": "#/$defs/absolutePath"
    },
    "staging_root": {
      "$ref": "#/$defs/absolutePath"
    },
    "config_existed_before": {
      "type": "boolean"
    },
    "config_before_sha256": {
      "$ref": "#/$defs/sha256Hex"
    },
    "config_after_sha256": {
      "anyOf": [
        {
          "$ref": "#/$defs/sha256Hex"
        },
        {
          "type": "null"
        }
      ]
    },
    "backup_path": {
      "anyOf": [
        {
          "$ref": "#/$defs/absolutePath"
        },
        {
          "type": "null"
        }
      ]
    },
    "backup_sha256": {
      "anyOf": [
        {
          "$ref": "#/$defs/sha256Hex"
        },
        {
          "type": "null"
        }
      ]
    },
    "managed_entry_original": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "present",
        "digest"
      ],
      "properties": {
        "present": {
          "const": false
        },
        "digest": {
          "type": "null"
        }
      }
    },
    "managed_entry": {
      "$ref": "#/$defs/managedEntry"
    },
    "codex_runtime": {
      "$ref": "#/$defs/runtimeIdentity"
    },
    "python_runtime": {
      "$ref": "#/$defs/runtimeIdentity"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/stagedArtifact"
      }
    },
    "normal_integration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_version",
        "receipt_path",
        "receipt_sha256",
        "doctor_ready"
      ],
      "properties": {
        "receipt_version": {
          "const": "1.0.0"
        },
        "receipt_path": {
          "$ref": "#/$defs/absolutePath"
        },
        "receipt_sha256": {
          "$ref": "#/$defs/sha256Hex"
        },
        "doctor_ready": {
          "const": true
        }
      }
    },
    "teardown": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested_at",
        "completed_at",
        "config_after_teardown_sha256"
      ],
      "properties": {
        "requested_at": {
          "anyOf": [
            {
              "$ref": "#/$defs/dateTime"
            },
            {
              "type": "null"
            }
          ]
        },
        "completed_at": {
          "anyOf": [
            {
              "$ref": "#/$defs/dateTime"
            },
            {
              "type": "null"
            }
          ]
        },
        "config_after_teardown_sha256": {
          "anyOf": [
            {
              "$ref": "#/$defs/sha256Hex"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "config_existed_before": {
            "const": true
          }
        },
        "required": [
          "config_existed_before"
        ]
      },
      "then": {
        "properties": {
          "backup_path": {
            "$ref": "#/$defs/absolutePath"
          },
          "backup_sha256": {
            "$ref": "#/$defs/sha256Hex"
          }
        }
      },
      "else": {
        "properties": {
          "config_before_sha256": {
            "const": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
          },
          "backup_path": {
            "type": "null"
          },
          "backup_sha256": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "state": {
            "const": "prepared"
          }
        },
        "required": [
          "state"
        ]
      },
      "then": {
        "properties": {
          "config_after_sha256": {
            "type": "null"
          },
          "teardown": {
            "$ref": "#/$defs/emptyTeardown"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "state": {
            "const": "installed"
          }
        },
        "required": [
          "state"
        ]
      },
      "then": {
        "properties": {
          "config_after_sha256": {
            "$ref": "#/$defs/sha256Hex"
          },
          "teardown": {
            "$ref": "#/$defs/emptyTeardown"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "state": {
            "const": "removing"
          }
        },
        "required": [
          "state"
        ]
      },
      "then": {
        "properties": {
          "config_after_sha256": {
            "$ref": "#/$defs/sha256Hex"
          },
          "teardown": {
            "$ref": "#/$defs/removingTeardown"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "state": {
            "const": "removed"
          }
        },
        "required": [
          "state"
        ]
      },
      "then": {
        "properties": {
          "config_after_sha256": {
            "$ref": "#/$defs/sha256Hex"
          },
          "teardown": {
            "$ref": "#/$defs/completedTeardown"
          }
        }
      }
    }
  ],
  "$defs": {
    "sha256Hex": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time",
      "maxLength": 64
    },
    "absolutePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "description": "A platform-absolute local path. Runtime validation MUST use pathlib, reject NUL and symlinks where required, and enforce expected-root containment."
    },
    "relativeArtifactPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
    },
    "runtimeIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "version",
        "size_bytes"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/absolutePath"
        },
        "sha256": {
          "$ref": "#/$defs/sha256Hex"
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[ -~]+$"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1073741824
        }
      }
    },
    "stagedArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relative_path",
        "sha256",
        "size_bytes",
        "file_mode"
      ],
      "properties": {
        "relative_path": {
          "$ref": "#/$defs/relativeArtifactPath"
        },
        "sha256": {
          "$ref": "#/$defs/sha256Hex"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1048576
        },
        "file_mode": {
          "const": "0600"
        }
      }
    },
    "managedEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "canonicalization",
        "sha256",
        "transport",
        "command",
        "args",
        "cwd",
        "enabled",
        "required",
        "startup_timeout_sec",
        "tool_timeout_sec",
        "enabled_tools",
        "default_tools_approval_mode",
        "tool_overrides"
      ],
      "properties": {
        "name": {
          "const": "verity_cordon_poisoned_docs"
        },
        "canonicalization": {
          "const": "VC-TOML-MANAGED-1"
        },
        "sha256": {
          "$ref": "#/$defs/sha256Hex"
        },
        "transport": {
          "const": "stdio"
        },
        "command": {
          "$ref": "#/$defs/absolutePath"
        },
        "args": {
          "type": "array",
          "prefixItems": [
            {
              "const": "-I"
            },
            {
              "$ref": "#/$defs/absolutePath"
            }
          ],
          "items": false,
          "minItems": 2,
          "maxItems": 2
        },
        "cwd": {
          "$ref": "#/$defs/absolutePath"
        },
        "enabled": {
          "const": true
        },
        "required": {
          "const": true
        },
        "startup_timeout_sec": {
          "const": 5
        },
        "tool_timeout_sec": {
          "const": 5
        },
        "enabled_tools": {
          "const": [
            "get_release_guidance",
            "demo_artifact_sink"
          ]
        },
        "default_tools_approval_mode": {
          "const": "writes"
        },
        "tool_overrides": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "demo_artifact_sink"
          ],
          "properties": {
            "demo_artifact_sink": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "approval_mode"
              ],
              "properties": {
                "approval_mode": {
                  "const": "prompt"
                }
              }
            }
          }
        }
      }
    },
    "emptyTeardown": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested_at",
        "completed_at",
        "config_after_teardown_sha256"
      ],
      "properties": {
        "requested_at": {
          "type": "null"
        },
        "completed_at": {
          "type": "null"
        },
        "config_after_teardown_sha256": {
          "type": "null"
        }
      }
    },
    "removingTeardown": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested_at",
        "completed_at",
        "config_after_teardown_sha256"
      ],
      "properties": {
        "requested_at": {
          "$ref": "#/$defs/dateTime"
        },
        "completed_at": {
          "type": "null"
        },
        "config_after_teardown_sha256": {
          "type": "null"
        }
      }
    },
    "completedTeardown": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested_at",
        "completed_at",
        "config_after_teardown_sha256"
      ],
      "properties": {
        "requested_at": {
          "$ref": "#/$defs/dateTime"
        },
        "completed_at": {
          "$ref": "#/$defs/dateTime"
        },
        "config_after_teardown_sha256": {
          "$ref": "#/$defs/sha256Hex"
        }
      }
    }
  }
}
