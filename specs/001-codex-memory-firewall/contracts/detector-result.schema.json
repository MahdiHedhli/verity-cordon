{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:verity-cordon:schema:detector-result:1.0.0",
  "title": "Verity Cordon Detector Result",
  "description": "A deterministic detector finding or explicit detector failure. Messages and metadata are content-safe and must not contain matched secret values.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "result_id",
    "candidate_id",
    "detector_id",
    "detector_version",
    "execution_order",
    "status",
    "matched",
    "severity",
    "confidence",
    "categories",
    "message",
    "evidence_offsets",
    "metadata",
    "failure_class",
    "latency_ms",
    "recorded_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "result_id": {
      "$ref": "#/$defs/identifier"
    },
    "candidate_id": {
      "$ref": "#/$defs/identifier"
    },
    "detector_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]{2,63}$"
    },
    "detector_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "execution_order": {
      "type": "integer",
      "minimum": 0
    },
    "status": {
      "enum": [
        "ok",
        "timeout",
        "error",
        "cancelled",
        "malformed"
      ]
    },
    "matched": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "severity": {
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "categories": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/category"
      }
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "evidence_offsets": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_ref",
          "start",
          "end"
        ],
        "properties": {
          "source_ref": {
            "$ref": "#/$defs/identifier"
          },
          "start": {
            "type": "integer",
            "minimum": 0
          },
          "end": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Content-free detector metadata. Raw matches and secret values are prohibited.",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "integer",
          "boolean",
          "null"
        ]
      }
    },
    "failure_class": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Za-z][A-Za-z0-9_.-]{0,127}$"
    },
    "latency_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 300000
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "ok"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "matched": {
            "type": "boolean"
          },
          "failure_class": {
            "type": "null"
          }
        }
      },
      "else": {
        "properties": {
          "matched": {
            "type": "null"
          },
          "failure_class": {
            "type": "string"
          }
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{7,127}$"
    },
    "category": {
      "enum": [
        "credential_material",
        "pii",
        "persistent_instruction",
        "protected_namespace",
        "cross_task_contamination",
        "self_reinforcement",
        "untrusted_authority",
        "anomalous_size",
        "concealed_instruction",
        "encoded_content",
        "structural_invalidity"
      ]
    }
  }
}
